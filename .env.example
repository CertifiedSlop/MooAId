# MooAId Environment Configuration
# Copy this file to .env and fill in your values

# MooAId Configuration
MOOAID_PORT=8000
MOOAID_PROVIDER=openrouter

# OpenRouter API Key (required if using openrouter provider)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI API Key (required if using openai provider)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API Key (required if using gemini provider)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Ollama Configuration (for local models)
OLLAMA_HOST=http://ollama:11434
